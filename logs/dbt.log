    create  table
      "nem"."main_silver"."silver_emissions_factor__dbt_tmp"
  
    as (
      -- models/silver/silver_emissions_factor.sql
-- Scope 1 emissions factors only, with a normalised join key.
-- Scope 3 factors exist in Bronze but are excluded from the intensity calculation.

with source as (
    select * from "nem"."bronze"."emissions_factors"
),

scope1 as (
    select
        lower(trim(technology_type))       as technology_type_key,
        trim(technology_type)              as technology_type,
        cast(emission_factor_tCO2e_MWh as double) as emission_factor_tCO2e_MWh
    from source
    where scope = 'scope_1'
)

select * from scope1
    );
  
  
[0m20:00:45.422214 [debug] [Thread-1 (]: SQL status: OK in 0.001 seconds
[0m20:00:45.422367 [debug] [Thread-1 (]: Using duckdb connection "model.nem_pipeline.silver_dispatch_interval"
[0m20:00:45.422533 [debug] [Thread-1 (]: On model.nem_pipeline.silver_dispatch_interval: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "nem_pipeline", "target_name": "dev", "node_id": "model.nem_pipeline.silver_dispatch_interval"} */

  
    
    

    create  table
      "nem"."main_silver"."silver_dispatch_interval__dbt_tmp"
  
    as (
      -- models/silver/silver_dispatch_interval.sql
-- Typed, deduplicated SCADA dispatch intervals with a data-quality flag.

with source as (
    select * from "nem"."bronze"."dispatch_scada"
),

typed as (
    select
        cast(SETTLEMENTDATE as timestamp) as settlement_date,
        trim(DUID)                         as duid,
        cast(SCADAVALUE as double)         as scada_mw
    from source
    where SETTLEMENTDATE is not null
      and DUID is not null
),

deduped as (
    select *
    from typed
    qualify row_number() over (
        partition by settlement_date, duid
        order by settlement_date
    ) = 1
),

final as (
    select
        settlement_date,
        duid,
        scada_mw,
        -- Flag readings that are physically implausible
        (scada_mw < 0 or scada_mw > 5000) as dq_flag
    from deduped
)

select * from final
    );
  
  
